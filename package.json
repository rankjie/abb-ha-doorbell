{
  "name": "@rankjie/abb-ha-doorbell",
  "version": "0.1.2",
  "description": "ABB Welcome doorbell bridge for Scrypted via Home Assistant",
  "keywords": [
    "scrypted",
    "plugin",
    "abb",
    "doorbell",
    "camera",
    "homekit",
    "home-assistant"
  ],
  "homepage": "https://github.com/rankjie/abb-ha-doorbell#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rankjie/abb-ha-doorbell.git"
  },
  "license": "MIT",
  "main": "src/main.ts",
  "exports": {
    "./src/main.ts": "./main.nodejs.js"
  },
  "scripts": {
    "build": "npm run typecheck && scrypted-webpack",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && NODE_ENV=production scrypted-webpack",
    "scrypted-webpack": "scrypted-webpack",
    "scrypted-deploy": "scrypted-deploy"
  },
  "dependencies": {
    "@scrypted/sdk": "^0.5.59",
    "ws": "^7.5.11"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3"
  },
  "scrypted": {
    "name": "ABB HA Doorbell",
    "type": "DeviceProvider",
    "interfaces": [
      "DeviceProvider",
      "Settings"
    ]
  }
}
